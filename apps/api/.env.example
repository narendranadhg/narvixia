# ==========================================
# Application
# ==========================================
APP_NAME=Registration AI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ==========================================
# Database
# ==========================================
DATABASE_URL=postgresql://username:password@localhost:5432/registration_ai

# ==========================================
# Security
# ==========================================
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# CORS
# ==========================================
ALLOWED_ORIGINS=http://localhost:5173

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO